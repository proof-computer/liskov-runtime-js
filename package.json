{
  "name": "@proof-computer/liskov-runtime",
  "version": "0.3.7",
  "private": false,
  "description": "Job-side Liskov runtime bootstrap SDK for PROOF Applications on Acurast.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/proof-computer/liskov-runtime-js.git"
  },
  "homepage": "https://github.com/proof-computer/liskov-runtime-js#readme",
  "bugs": {
    "url": "https://github.com/proof-computer/liskov-runtime-js/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist",
    "README.md",
    "SECURITY.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./acurast": {
      "types": "./dist/acurast.d.ts",
      "import": "./dist/acurast.js"
    },
    "./blackbox-logger": {
      "types": "./dist/blackbox-logger.d.ts",
      "import": "./dist/blackbox-logger.js"
    },
    "./bootstrap": {
      "types": "./dist/bootstrap.d.ts",
      "import": "./dist/bootstrap.js"
    },
    "./diagnostics": {
      "types": "./dist/diagnostics.d.ts",
      "import": "./dist/diagnostics.js"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "import": "./dist/env.js"
    },
    "./home": {
      "types": "./dist/home.d.ts",
      "import": "./dist/home.js"
    },
    "./lockbox": {
      "types": "./dist/lockbox.d.ts",
      "import": "./dist/lockbox.js"
    },
    "./proof-log-crypto": {
      "types": "./dist/proof-log-crypto.d.ts",
      "import": "./dist/proof-log-crypto.js"
    },
    "./runtime-env": {
      "types": "./dist/runtime-env.d.ts",
      "import": "./dist/runtime-env.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "pack:dry-run": "npm pack --dry-run --json",
    "prepare": "npm run build",
    "test": "node --import tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
